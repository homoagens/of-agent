# OF-Agent environment configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# LLM backend — any OpenAI-compatible API endpoint
OF_AGENT_BACKEND_URL=http://localhost:11434

# API key (required by some backends; use any string for local Ollama/llama.cpp)
OF_AGENT_BACKEND_KEY=local

# Model name as recognised by your backend
# Examples: llama3.1:8b, qwen2.5:14b, gemma3:12b, gpt-4o, claude-sonnet-4-6
OF_AGENT_MODEL=llama3.1:8b

# Sampling temperature (0.0 = deterministic, 1.0 = creative; 0.2 recommended)
OF_AGENT_TEMPERATURE=0.2
